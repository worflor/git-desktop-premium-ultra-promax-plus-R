<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Keep the app unsandboxed: it shells out to git against arbitrary
	     user repositories. Sandboxing this target needs security-scoped
	     bookmark plumbing and subprocess-safe file access first. -->
</dict>
</plist>
