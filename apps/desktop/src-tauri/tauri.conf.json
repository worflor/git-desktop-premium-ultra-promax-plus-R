{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Desktop",
  "version": "0.1.0",
  "identifier": "com.gdpu.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Git Desktop",
        "width": 980,
        "height": 660,
        "minWidth": 620,
        "minHeight": 500,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "updater": {
      "pubkey": "RWQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
      "endpoints": []
    }
  }
}
