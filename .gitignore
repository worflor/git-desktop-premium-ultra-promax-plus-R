# Node
node_modules/
dist/
.vite/

# Rust
/target/
**/*.rs.bk

# Tauri
src-tauri/target/
apps/desktop/src-tauri/target/

# Claude Code local state — session locks, agent configs, ephemeral
# PIDs, etc. Nothing under here is shared across contributors.
.claude/

# Codex (OpenAI CLI) scratch directories — per-invocation probes
# (ffcheck / status / status_unicode variants) with UUID-suffixed
# names. Agent creates and abandons them; they should never reach
# the repo. Anchored to root: Codex only drops these in CWD, and an
# unanchored pattern would mask any same-named dir at any depth.
/.codex_tmp_*/

# Local git worktrees. Worktree paths are dev-local — different
# contributors check out feature branches into different sub-paths.
# The branches themselves live in the repo's history; the on-disk
# checkouts don't belong in the tree.
.manifold/

# IDE and OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log

# Env
.env
.env.*
apps/desktop-flutter/build_log.txt

# Research scratchpad — autonomous-session probes, tm_/tmp_ scripts,
# staging markdowns, __pycache__. Lives in-tree so the work is
# retrievable locally but never bloats git history. If a specific
# probe graduates to production, it gets a home under
# apps/desktop-flutter/test/research/ or docs/architecture/ and is
# added back explicitly.
/research_lab/

# Historical docs — already pushed to remote. Kept locally for
# reference but don't need to track changes going forward.
/docs/planning/
/docs/research/
/docs/ui/
/fixtures/

# Build / debug artifacts
globals_dump.css
typecheck.txt
